# Helius RPC URLs (get from https://www.helius.dev/)
HELIUS_MAINNET_URL=https://mainnet.helius-rpc.com/?api-key=YOUR_API_KEY
HELIUS_DEVNET_URL=https://devnet.helius-rpc.com/?api-key=YOUR_API_KEY

# Pinata IPFS (get from https://www.pinata.cloud/)
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_api_key

# Server
PORT=3001
NODE_ENV=development
